<Window x:Class="DMTools.Pages.SpecialAbilitiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Special Ability" Width="800" Height="620"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="#F2080000">
    <Window.Resources>

        <Style x:Key="SlimScroll" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#77E69A28" CornerRadius="2" Margin="1,3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScroll}"/>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
            <Setter Property="SelectionBrush" Value="#66E69A28"/>
        </Style>

        <Style x:Key="FilterInput" TargetType="TextBox" BasedOn="{StaticResource DarkInput}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Non-editable dark combo (for casting ability) -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="#44FFFFFF"
                                                BorderBrush="#77E69A28" BorderThickness="1" CornerRadius="1" MinHeight="32">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#88E69A28"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#AAE69A28"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" Margin="9,0,28,0"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="#F5E6D3"
                                              TextBlock.FontFamily="Georgia"
                                              TextBlock.FontSize="12"/>
                            <Popup x:Name="PART_Popup" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#F0120000" BorderBrush="#88E69A28" BorderThickness="1" CornerRadius="1">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F5E6D3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33E69A28"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#55E69A28"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Library results list -->
        <Style x:Key="LibraryList" TargetType="ListBox">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="Foreground" Value="#F0E6D3"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#22E69A28"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#44E69A28"/>
                                            <Setter Property="Foreground" Value="#FFE69A28"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFE69A28"/>
            <Setter Property="Background" Value="#66E69A28"/>
            <Setter Property="BorderBrush" Value="#AAE69A28"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
        </Style>

        <Style x:Key="ClearBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F50A0000"
                BorderBrush="#55E69A28" BorderThickness="0,0,0,1" Padding="20,12">
            <TextBlock Text="Special Ability"
                       FontFamily="Georgia" FontSize="20" FontStyle="Italic"
                       Foreground="#FFE69A28"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,14,16,10">
            <StackPanel>

                <!-- ── FROM LIBRARY ──────────────────────────────────── -->
                <TextBlock FontFamily="Georgia" FontSize="9" FontWeight="Bold"
                           Foreground="#CCE69A28" Margin="0,0,0,8"
                           Text="FROM LIBRARY"/>

                <!-- Filter row -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MONSTER" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtFilterMonster" Style="{StaticResource FilterInput}"
                                 TextChanged="OnFilterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ABILITY NAME" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtFilterName" Style="{StaticResource FilterInput}"
                                 TextChanged="OnFilterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="DESCRIPTION TEXT" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtFilterDesc" Style="{StaticResource FilterInput}"
                                 TextChanged="OnFilterChanged"/>
                    </StackPanel>
                    <Button Grid.Column="6" Content="Clear" Style="{StaticResource ClearBtn}"
                            VerticalAlignment="Bottom" Margin="0,0,0,0" Click="btnClearFilters_Click"/>
                </Grid>

                <!-- Filtered results list -->
                <ListBox Name="lbAbilities" Style="{StaticResource LibraryList}"
                         DisplayMemberPath="DisplayName"
                         MaxHeight="165" Margin="0,0,0,8"/>

                <!-- Casting ability + PB + Apply -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="190"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="CASTING ABILITY" Style="{StaticResource Lbl}" Margin="0,0,0,0"/>
                        <TextBlock FontFamily="Georgia" FontSize="8" FontStyle="Italic"
                                   Foreground="#55E69A28" Text="for DC &amp; attack recalc"/>
                    </StackPanel>

                    <ComboBox Name="cboCastingAbility" Grid.Column="2" Style="{StaticResource DarkCombo}"/>

                    <TextBlock Name="lblProficiency" Grid.Column="4"
                               FontFamily="Georgia" FontSize="13" FontWeight="Bold"
                               Foreground="#AAE69A28" VerticalAlignment="Center"/>

                    <Button Grid.Column="6" Content="Apply"
                            Style="{StaticResource AmberBtn}" Padding="18,7"
                            Click="btnApply_Click"/>
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="#33E69A28" Margin="0,14,0,14"/>

                <!-- Name -->
                <TextBlock Text="NAME" Style="{StaticResource Lbl}"/>
                <TextBox Text="{Binding SpecialAbility.Name, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkInput}" Margin="0,0,0,12"/>

                <!-- Description -->
                <TextBlock Text="DESCRIPTION" Style="{StaticResource Lbl}"/>
                <TextBox Text="{Binding SpecialAbility.Description, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkInput}"
                         AcceptsReturn="True" Height="200" TextWrapping="Wrap"
                         VerticalContentAlignment="Top" Padding="8,6"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F50A0000"
                BorderBrush="#33E69A28" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="btnCancel_Click"/>
                <Button Content="Save"   Style="{StaticResource AmberBtn}"                  Click="btnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
