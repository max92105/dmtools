<Page x:Class="DMTools.Pages.ConfigurationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1280"
      Background="#F2080000"
      Loaded="Page_Loaded" Title="Configuration">

    <Page.Resources>

        <Style x:Key="SlimScroll" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#77E69A28" CornerRadius="2" Margin="1,3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScroll}"/>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
            <Setter Property="SelectionBrush" Value="#66E69A28"/>
        </Style>

        <Style x:Key="DarkList" TargetType="ListBox">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Foreground" Value="#F0E6D3"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#22E69A28"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#44E69A28"/>
                                            <Setter Property="Foreground" Value="#FFE69A28"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFE69A28"/>
            <Setter Property="Background" Value="#66E69A28"/>
            <Setter Property="BorderBrush" Value="#AAE69A28"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55FF5555"/>
            <Setter Property="Foreground" Value="#CCFF9999"/>
        </Style>

        <Style x:Key="SmBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="SmAmberBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <Style x:Key="SmDangerBtn" TargetType="Button" BasedOn="{StaticResource DangerBtn}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F50A0000"
                BorderBrush="#55E69A28" BorderThickness="0,0,0,1" Padding="24,0">
            <TextBlock Text="Configuration"
                       FontFamily="Georgia" FontSize="22" FontStyle="Italic"
                       Foreground="#FFE69A28" VerticalAlignment="Center"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,28">

                <!-- Two panels side by side -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══ MONSTER TYPES ═══ -->
                    <Border Grid.Column="0"
                            Background="#0DFFFFFF" BorderBrush="#33E69A28"
                            BorderThickness="1" CornerRadius="3" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="MONSTER TYPES" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>

                            <ListBox x:Name="lbTypes" Grid.Row="1"
                                     DisplayMemberPath="Name"
                                     Style="{StaticResource DarkList}"
                                     MinHeight="260" MaxHeight="480"
                                     SelectionChanged="lbTypes_SelectionChanged"/>

                            <TextBlock Grid.Row="3" Text="NAME" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="txtTypeName" Grid.Row="3"
                                     Style="{StaticResource DarkInput}"
                                     Margin="0,18,0,0"/>

                            <StackPanel Grid.Row="5" Orientation="Horizontal">
                                <Button Content="+ Add"  Style="{StaticResource SmAmberBtn}" Margin="0,0,6,0" Click="btnAddType_Click"/>
                                <Button Content="Rename" Style="{StaticResource SmBtn}"      Margin="0,0,6,0" Click="btnRenameType_Click"/>
                                <Button Content="Delete" Style="{StaticResource SmDangerBtn}"               Click="btnDeleteType_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ═══ MONSTER SUBTYPES ═══ -->
                    <Border Grid.Column="2"
                            Background="#0DFFFFFF" BorderBrush="#33E69A28"
                            BorderThickness="1" CornerRadius="3" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="MONSTER SUBTYPES" Style="{StaticResource Lbl}" Margin="0,0,0,6"/>

                            <ListBox x:Name="lbSubtypes" Grid.Row="1"
                                     DisplayMemberPath="Name"
                                     Style="{StaticResource DarkList}"
                                     MinHeight="260" MaxHeight="480"
                                     SelectionChanged="lbSubtypes_SelectionChanged"/>

                            <TextBlock Grid.Row="3" Text="NAME" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="txtSubtypeName" Grid.Row="3"
                                     Style="{StaticResource DarkInput}"
                                     Margin="0,18,0,0"/>

                            <StackPanel Grid.Row="5" Orientation="Horizontal">
                                <Button Content="+ Add"  Style="{StaticResource SmAmberBtn}" Margin="0,0,6,0" Click="btnAddSubtype_Click"/>
                                <Button Content="Rename" Style="{StaticResource SmBtn}"      Margin="0,0,6,0" Click="btnRenameSubtype_Click"/>
                                <Button Content="Delete" Style="{StaticResource SmDangerBtn}"               Click="btnDeleteSubtype_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>

                <!-- Info note -->
                <TextBlock Margin="0,16,0,0"
                           FontFamily="Georgia" FontSize="11" FontStyle="Italic"
                           Foreground="#44E69A28"
                           Text="Changes take effect immediately. Monster Editor dropdowns will reflect these lists on next open."/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
