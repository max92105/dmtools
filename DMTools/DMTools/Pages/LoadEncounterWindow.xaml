<Window x:Class="DMTools.Pages.LoadEncounterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Width="380" Height="460"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#F2100800">

    <Border BorderBrush="#88E69A28" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#F50A0000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Load Encounter"
                           FontFamily="Georgia" FontSize="14" FontStyle="Italic"
                           Foreground="#E69A28" VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Content="&#x2715;" Click="btnCancel_Click"
                        HorizontalAlignment="Right" Width="38" Height="38"
                        Foreground="#88E6D3B8" Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#CCC42B1A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#88E6D3B8"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Rectangle Height="1" VerticalAlignment="Bottom" Fill="#44E69A28"/>
            </Grid>

            <!-- Search box -->
            <Border Grid.Row="1" Background="#F00A0000"
                    BorderBrush="#33E69A28" BorderThickness="0,0,0,1"
                    Padding="12,10">
                <TextBox x:Name="txtSearch"
                         Background="#44FFFFFF" Foreground="#F0E6D3"
                         BorderBrush="#66E69A28" BorderThickness="1"
                         FontFamily="Georgia" FontSize="13"
                         Padding="8,5" CaretBrush="#E69A28"
                         TextChanged="txtSearch_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Border>

            <!-- Encounter list -->
            <ListBox x:Name="lbEncounters" Grid.Row="2"
                     Background="Transparent" BorderThickness="0"
                     Foreground="#F0E6D3" FontFamily="Georgia" FontSize="14"
                     SelectionChanged="lbEncounters_SelectionChanged"
                     MouseDoubleClick="lbEncounters_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                                            BorderBrush="#22E69A28" BorderThickness="0,0,0,1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#33E69A28"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#55E69A28"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"
                                   FontFamily="Georgia" FontSize="14" Foreground="#F5E6D3"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Rectangle Grid.Row="3" Fill="#44E69A28"/>

            <!-- Buttons -->
            <Grid Grid.Row="4" Margin="16,12,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Cancel" Click="btnCancel_Click"
                        FontFamily="Georgia" FontSize="13" Padding="18,8" Cursor="Hand"
                        Background="Transparent" BorderBrush="#44E69A28" Foreground="#99E6D3B8">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="FontFamily" Value="Georgia"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="18,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="btnLoad" Grid.Column="3" Content="Load" IsEnabled="False"
                        Click="btnLoad_Click"
                        FontFamily="Georgia" FontSize="13" Padding="18,8" Cursor="Hand"
                        Background="#55E69A28" BorderBrush="#99E69A28" Foreground="#FFE69A28">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="FontFamily" Value="Georgia"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="18,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
