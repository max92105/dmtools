<Page x:Class="DMTools.Pages.EncounterBuilderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1280"
      Loaded="Page_Loaded" Title="Encounter Builder">

    <Page.Resources>
        <Style x:Key="PanelLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#CCE69A28"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderBrush" Value="#44E69A28"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RemoveButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent"
                                BorderBrush="#44C42B1A" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33C42B1A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#66C42B1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#55E69A28" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Background -->
        <Image Grid.RowSpan="2" Source="/Ressource/DNDBackground.png" Stretch="UniformToFill"/>

        <!-- Header -->
        <Rectangle Grid.Row="0" Fill="#CC0A0000"/>
        <TextBlock Grid.Row="0" Text="Encounter Builder"
                   FontFamily="Georgia" FontSize="22" FontStyle="Italic"
                   Foreground="#E69A28" VerticalAlignment="Center" Margin="24,0,0,0"/>

        <!-- 3-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: Monster browser ═══ -->
            <DockPanel Grid.Column="0" Background="#CC0A0000" LastChildFill="True">
                <!-- Title -->
                <TextBlock DockPanel.Dock="Top" Text="MONSTERS"
                           FontFamily="Georgia" FontSize="11" FontWeight="Bold"
                           Foreground="#CCE69A28" Margin="12,14,12,8"/>
                <!-- Search -->
                <TextBox DockPanel.Dock="Top" x:Name="txtMonsterSearch"
                         Style="{StaticResource FieldBox}" Margin="12,0,12,8"
                         TextChanged="txtMonsterSearch_TextChanged"/>
                <!-- Monster list -->
                <ScrollViewer x:Name="monsterScroll" Margin="0,0,0,0">
                    <ListBox x:Name="lbMonsters" Background="Transparent" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="lbMonsters_SelectionChanged"
                             PreviewMouseWheel="lbMonsters_PreviewMouseWheel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,7"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    BorderBrush="Transparent" BorderThickness="0,0,0,1"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#22E69A28"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#44E69A28"/>
                                                    <Setter TargetName="bg" Property="BorderBrush" Value="#44E69A28"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Georgia" FontSize="13"
                                           Foreground="#F0E6D3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Grid.Column="1" Fill="#33E69A28"/>

            <!-- ═══ CENTER: Encounter composer ═══ -->
            <Grid Grid.Column="2" Margin="20,14,20,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Section title -->
                <TextBlock Grid.Row="0" Text="CURRENT ENCOUNTER"
                           FontFamily="Georgia" FontSize="11" FontWeight="Bold"
                           Foreground="#CCE69A28" Margin="0,0,0,14"/>

                <!-- Encounter name -->
                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <TextBlock Text="NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="txtEncounterName" Style="{StaticResource FieldBox}"/>
                </StackPanel>

                <!-- Add monster row -->
                <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#22FFFFFF" BorderBrush="#44E69A28"
                            BorderThickness="0,0,0,1" Padding="6,5">
                        <TextBlock x:Name="tbSelectedMonster" Text="— select a monster —"
                                   FontFamily="Georgia" FontSize="13"
                                   Foreground="#55E6D3B8" FontStyle="Italic"/>
                    </Border>
                    <TextBox x:Name="txtAddQty" Grid.Column="2" Text="1"
                             Style="{StaticResource FieldBox}" TextAlignment="Center"
                             PreviewTextInput="txtQty_PreviewTextInput"/>
                    <Button x:Name="btnAddToEncounter" Grid.Column="4" Content="Add"
                            Style="{StaticResource ActionButton}" IsEnabled="False"
                            Background="#33E69A28" BorderBrush="#66E69A28" Foreground="#E69A28"
                            Click="btnAddToEncounter_Click"/>
                </Grid>

                <!-- Divider -->
                <Rectangle Grid.Row="3" Height="1" Fill="#22E69A28" Margin="0,0,0,10"/>

                <!-- Current entries -->
                <ScrollViewer Grid.Row="4" x:Name="entriesScroll">
                    <ListBox x:Name="lbCurrentEntries" Background="Transparent" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="lbCurrentEntries_PreviewMouseWheel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#18E69A28" BorderBrush="#22E69A28"
                                        BorderThickness="0,0,0,1" Padding="10,8" Margin="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding MonsterName}"
                                                   FontFamily="Georgia" FontSize="13"
                                                   Foreground="#F0E6D3" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Quantity, StringFormat='×{0}'}"
                                                   FontFamily="Georgia" FontSize="13"
                                                   Foreground="#E69A28" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="×" Tag="{Binding}"
                                                Style="{StaticResource RemoveButton}"
                                                Foreground="#AA9060" VerticalAlignment="Center"
                                                Click="btnRemoveEntry_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Action buttons -->
                <Grid Grid.Row="5" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Clear" x:Name="btnClearEncounter"
                            Style="{StaticResource ActionButton}"
                            Background="Transparent" BorderBrush="#44E69A28" Foreground="#88E6D3B8"
                            Click="btnClearEncounter_Click"/>
                    <Button Grid.Column="2" Content="Save" x:Name="btnSaveEncounter"
                            Style="{StaticResource ActionButton}"
                            Background="Transparent" BorderBrush="#66E69A28" Foreground="#CCE69A28"
                            Click="btnSaveEncounter_Click"/>
                    <Button Grid.Column="4" Content="▶  Run Encounter" x:Name="btnRunEncounter"
                            Style="{StaticResource ActionButton}"
                            Background="#44E69A28" BorderBrush="#88E69A28" Foreground="#E69A28"
                            Click="btnRunEncounter_Click"/>
                </Grid>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Column="3" Fill="#33E69A28"/>

            <!-- ═══ RIGHT: Saved encounters ═══ -->
            <DockPanel Grid.Column="4" Background="#CC0A0000" LastChildFill="True">
                <!-- Title -->
                <TextBlock DockPanel.Dock="Top" Text="SAVED ENCOUNTERS"
                           FontFamily="Georgia" FontSize="11" FontWeight="Bold"
                           Foreground="#CCE69A28" Margin="12,14,12,8"/>

                <!-- Load / Delete buttons pinned to bottom -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="12,0,12,14">
                    <Button x:Name="btnLoadEncounter" Content="Load" IsEnabled="False"
                            Style="{StaticResource ActionButton}"
                            Background="#33E69A28" BorderBrush="#66E69A28" Foreground="#CCE69A28"
                            Click="btnLoadEncounter_Click"/>
                    <Rectangle Width="8"/>
                    <Button x:Name="btnDeleteEncounter" Content="Delete" IsEnabled="False"
                            Style="{StaticResource ActionButton}"
                            Background="Transparent" BorderBrush="#44C42B1A" Foreground="#C07070"
                            Click="btnDeleteEncounter_Click"/>
                </StackPanel>

                <!-- Saved encounter list -->
                <ScrollViewer x:Name="savedScroll" Margin="0,0,0,8">
                    <ListBox x:Name="lbSavedEncounters" Background="Transparent" BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             SelectionChanged="lbSavedEncounters_SelectionChanged"
                             PreviewMouseWheel="lbSavedEncounters_PreviewMouseWheel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                    BorderBrush="Transparent" BorderThickness="0,0,0,1"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#22E69A28"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#44E69A28"/>
                                                    <Setter TargetName="bg" Property="BorderBrush" Value="#44E69A28"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Georgia" FontSize="13"
                                           Foreground="#F0E6D3" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </DockPanel>

        </Grid>
    </Grid>
</Page>
