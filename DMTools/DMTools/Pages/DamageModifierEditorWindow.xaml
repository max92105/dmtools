<Window x:Class="DMTools.Pages.DamageModifierEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Damage Modifier" Height="230" Width="380" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Damage Type" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox Name="cboDamageType" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

        <Label Content="Modifier Type" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox Name="cboModifierType" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"
                  SelectionChanged="cboModifierType_SelectionChanged"/>

        <Label Name="lblDiceCount" Content="Dice Count" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox Name="txtDiceCount" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>

        <Label Name="lblDiceSize" Content="Dice Size" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox Name="cboDiceSize" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"/>

        <Button Content="OK" Grid.Row="4" Grid.Column="1" Width="80" HorizontalAlignment="Right"
                VerticalAlignment="Center" Click="btnOk_Click"/>
    </Grid>
</Window>
