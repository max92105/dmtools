<Page x:Class="DMTools.Pages.MonsterManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="720" d:DesignWidth="1280"
      Loaded="Page_Loaded" Title="Monster Manager"
      Background="#F2080000">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="SlimScroll" TargetType="ScrollBar">
            <Setter Property="Width" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#77E69A28" CornerRadius="2" Margin="0,3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScroll}"/>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
            <Setter Property="SelectionBrush" Value="#66E69A28"/>
        </Style>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFE69A28"/>
            <Setter Property="Background" Value="#66E69A28"/>
            <Setter Property="BorderBrush" Value="#AAE69A28"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#BBE6D3B8"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33E69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="MaxDropDownHeight" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggleButton" Cursor="Hand"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                            RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="#44FFFFFF"
                                                BorderBrush="#77E69A28" BorderThickness="1" CornerRadius="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0"/>
                                                <Border Grid.Column="1" BorderBrush="#33E69A28" BorderThickness="1,0,0,0">
                                                    <TextBlock Text="▾" Foreground="#AAE69A28" FontSize="11"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#AAE69A28"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentPresenter"
                                IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#F30A0000" BorderBrush="#88E69A28" BorderThickness="1" CornerRadius="2"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#F0E6D3"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#33E69A28"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#55E69A28"/>
                                            <Setter Property="Foreground" Value="#FFE69A28"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styled checkbox -->
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="bd" Width="14" Height="14"
                                Background="#22FFFFFF" BorderBrush="#66E69A28" BorderThickness="1" CornerRadius="2">
                            <TextBlock x:Name="check" Text="✓" FontFamily="Georgia" FontSize="11"
                                       Foreground="#FFE69A28" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="bd" Property="Background" Value="#44E69A28"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#AAE69A28"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#AAE69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F50A0000"
                BorderBrush="#55E69A28" BorderThickness="0,0,0,1">
            <TextBlock Text="Monster Manager"
                       FontFamily="Georgia" FontSize="24" FontStyle="Italic"
                       Foreground="#FFE69A28" VerticalAlignment="Center" Margin="24,0,0,0"/>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── FILTER SIDEBAR ── -->
            <Border Grid.Column="0" Background="#F80A0000"
                    BorderBrush="#55E69A28" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,14,14,14">

                        <TextBlock Text="NAME" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtSearchName" Style="{StaticResource DarkInput}"
                                 Margin="0,0,0,14" TextChanged="txtSearchName_TextChanged"/>

                        <TextBlock Text="TYPE" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbType" Style="{StaticResource DarkCombo}"
                                  Margin="0,0,0,14" SelectionChanged="cmbFilter_SelectionChanged"/>

                        <TextBlock Text="SUBTYPE" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="txtSubtype" Style="{StaticResource DarkInput}"
                                 Margin="0,0,0,14" TextChanged="txtSearchName_TextChanged"/>

                        <TextBlock Text="SIZE" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbSize" Style="{StaticResource DarkCombo}"
                                  Margin="0,0,0,14" SelectionChanged="cmbFilter_SelectionChanged"/>

                        <TextBlock Text="ALIGNMENT" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="cmbAlignment" Style="{StaticResource DarkCombo}"
                                  Margin="0,0,0,14" SelectionChanged="cmbFilter_SelectionChanged"/>

                        <TextBlock Text="CR" Style="{StaticResource Lbl}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtCrMin" Grid.Column="0" Style="{StaticResource DarkInput}"
                                     Padding="6,4" TextChanged="txtSearchName_TextChanged"/>
                            <TextBlock Grid.Column="1" Text="–" Foreground="#77E69A28"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtCrMax" Grid.Column="2" Style="{StaticResource DarkInput}"
                                     Padding="6,4" TextChanged="txtSearchName_TextChanged"/>
                        </Grid>

                        <TextBlock Text="HP" Style="{StaticResource Lbl}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtHpMin" Grid.Column="0" Style="{StaticResource DarkInput}"
                                     Padding="6,4" TextChanged="txtSearchName_TextChanged"/>
                            <TextBlock Grid.Column="1" Text="–" Foreground="#77E69A28"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtHpMax" Grid.Column="2" Style="{StaticResource DarkInput}"
                                     Padding="6,4" TextChanged="txtSearchName_TextChanged"/>
                        </Grid>

                        <TextBlock Text="AC" Style="{StaticResource Lbl}"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtAcMin" Grid.Column="0" Style="{StaticResource DarkInput}"
                                     Padding="6,4" TextChanged="txtSearchName_TextChanged"/>
                            <TextBlock Grid.Column="1" Text="–" Foreground="#77E69A28"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBox x:Name="txtAcMax" Grid.Column="2" Style="{StaticResource DarkInput}"
                                     Padding="6,4" TextChanged="txtSearchName_TextChanged"/>
                        </Grid>

                        <Rectangle Height="1" Fill="#33E69A28" Margin="0,0,0,12"/>
                        <Button Content="Clear Filters" Style="{StaticResource GhostBtn}"
                                HorizontalAlignment="Stretch" Click="btnClearFilters_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ── MAIN AREA ── -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Action bar -->
                <Border Grid.Row="0" Background="#F50A0000"
                        BorderBrush="#33E69A28" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="tbCount" Grid.Column="0"
                                   FontFamily="Georgia" FontSize="12" FontStyle="Italic"
                                   Foreground="#88E69A28" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="+ New Monster"
                                Style="{StaticResource AmberBtn}"
                                Click="btnNewMonster_Click"/>
                        <Button Grid.Column="4" Content="↑ Export Selected"
                                Style="{StaticResource GhostBtn}"
                                Click="btnExport_Click"/>
                        <Button Grid.Column="6" Content="↓ Import"
                                Style="{StaticResource GhostBtn}"
                                Click="btnImport_Click"/>
                    </Grid>
                </Border>

                <!-- Monster list -->
                <ItemsControl x:Name="icMonsters" Grid.Row="1"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter Margin="10,6,10,14"/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1,0,1" CornerRadius="3" BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="MonsterRow_MouseDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0DFFFFFF"/>
                                            <Setter Property="BorderBrush" Value="#33E69A28"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#22E69A28"/>
                                                    <Setter Property="BorderBrush" Value="#77E69A28"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#18E69A28"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid Margin="10,8,6,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Select checkbox -->
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                  Style="{StaticResource DarkCheck}"
                                                  VerticalAlignment="Center"/>

                                        <!-- Name + type line -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    Margin="8,0,10,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontFamily="Georgia" FontSize="14" FontWeight="Bold"
                                                       Foreground="#F5E6D3" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type}"
                                                           FontFamily="Georgia" FontSize="10"
                                                           Foreground="#AAE69A28"/>
                                                <TextBlock Text="{Binding Subtype, StringFormat=' · {0}'}"
                                                           FontFamily="Georgia" FontSize="10"
                                                           Foreground="#88E6D3B8"
                                                           Visibility="{Binding HasSubtype, Converter={StaticResource BoolVis}}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Stat chips -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <!-- CR -->
                                            <Border Background="#44E69A28" BorderBrush="#66E69A28" BorderThickness="1"
                                                    CornerRadius="2" Padding="6,2" Margin="0,0,4,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="CR " FontFamily="Georgia" FontSize="10"
                                                               Foreground="#99E69A28" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ChallengeRating}"
                                                               FontFamily="Georgia" FontSize="12" FontWeight="Bold"
                                                               Foreground="#FFE69A28" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- HP -->
                                            <Border Background="#22FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1"
                                                    CornerRadius="2" Padding="6,2" Margin="0,0,4,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="HP " FontFamily="Georgia" FontSize="10"
                                                               Foreground="#77E6D3B8" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding HitPoints}"
                                                               FontFamily="Georgia" FontSize="12" FontWeight="Bold"
                                                               Foreground="#CCF5E6D3" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- AC -->
                                            <Border Background="#22FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1"
                                                    CornerRadius="2" Padding="6,2" Margin="0,0,4,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="AC " FontFamily="Georgia" FontSize="10"
                                                               Foreground="#77E6D3B8" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ArmorClass}"
                                                               FontFamily="Georgia" FontSize="12" FontWeight="Bold"
                                                               Foreground="#CCF5E6D3" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Size -->
                                            <Border Background="#1AFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                                                    CornerRadius="2" Padding="6,2" Margin="0,0,4,0"
                                                    Visibility="{Binding HasSize, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding Size}"
                                                           FontFamily="Georgia" FontSize="10"
                                                           Foreground="#88E6D3B8" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Edit -->
                                        <Button Grid.Column="3" Content="✎" ToolTip="Edit"
                                                Style="{StaticResource IconBtn}" FontSize="14"
                                                Tag="{Binding}" Click="btnEdit_Click"/>
                                        <!-- Stat block -->
                                        <Button Grid.Column="4" Content="📋" ToolTip="Stat block"
                                                Style="{StaticResource IconBtn}"
                                                Tag="{Binding}" Click="btnStatBlock_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Grid>
</Page>
