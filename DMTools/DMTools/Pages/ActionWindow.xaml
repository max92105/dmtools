<Window x:Class="DMTools.Pages.ActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Action" Width="820" Height="700"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Background="#F2080000">
    <Window.Resources>

        <Style x:Key="SlimScroll" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#77E69A28" CornerRadius="2" Margin="1,3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Height="0" Opacity="0"
                                                  Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource SlimScroll}"/>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
            <Setter Property="SelectionBrush" Value="#66E69A28"/>
        </Style>

        <Style x:Key="FilterInput" TargetType="TextBox" BasedOn="{StaticResource DarkInput}">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Editable dark combo (for Name, Range) -->
        <Style x:Key="DarkEditCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="bd" Background="#44FFFFFF"
                                BorderBrush="#77E69A28" BorderThickness="1" CornerRadius="1" MinHeight="32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PART_EditableTextBox"
                                         Grid.Column="0"
                                         Background="Transparent"
                                         Foreground="#F5E6D3"
                                         BorderThickness="0"
                                         FontFamily="Georgia" FontSize="12"
                                         Padding="8,0"
                                         VerticalAlignment="Center"
                                         CaretBrush="#E69A28"
                                         SelectionBrush="#66E69A28"
                                         IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                                         Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}"/>
                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock Text="▾" Foreground="#88E69A28"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup"
                                       Grid.ColumnSpan="2"
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom" AllowsTransparency="True">
                                    <Border Background="#F0120000" BorderBrush="#88E69A28" BorderThickness="1" CornerRadius="1"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#AAE69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F5E6D3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33E69A28"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#55E69A28"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Non-editable dark combo -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="#44FFFFFF"
                                                BorderBrush="#77E69A28" BorderThickness="1" CornerRadius="1" MinHeight="32">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#88E69A28"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#AAE69A28"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" Margin="9,0,28,0"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="#F5E6D3"
                                              TextBlock.FontFamily="Georgia"
                                              TextBlock.FontSize="12"/>
                            <Popup x:Name="PART_Popup" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#F0120000" BorderBrush="#88E69A28" BorderThickness="1" CornerRadius="1">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F5E6D3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33E69A28"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#55E69A28"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Library list -->
        <Style x:Key="LibraryList" TargetType="ListBox">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="Foreground" Value="#F0E6D3"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#22E69A28"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#44E69A28"/>
                                            <Setter Property="Foreground" Value="#FFE69A28"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFE69A28"/>
            <Setter Property="Background" Value="#66E69A28"/>
            <Setter Property="BorderBrush" Value="#AAE69A28"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
        </Style>

        <Style x:Key="ClearBtn" TargetType="Button" BasedOn="{StaticResource GhostBtn}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#CCE69A28"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F50A0000"
                BorderBrush="#55E69A28" BorderThickness="0,0,0,1" Padding="20,12">
            <TextBlock Text="Action"
                       FontFamily="Georgia" FontSize="20" FontStyle="Italic"
                       Foreground="#FFE69A28"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,14,16,10">
            <StackPanel>

                <!-- ── FROM LIBRARY ──────────────────────────────────── -->
                <TextBlock Text="FROM LIBRARY" Style="{StaticResource SectionLabel}"/>

                <!-- Filter row -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MONSTER" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtFilterMonster" Style="{StaticResource FilterInput}"
                                 TextChanged="OnFilterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ACTION NAME" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtFilterName" Style="{StaticResource FilterInput}"
                                 TextChanged="OnFilterChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="DESCRIPTION TEXT" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtFilterDesc" Style="{StaticResource FilterInput}"
                                 TextChanged="OnFilterChanged"/>
                    </StackPanel>
                    <Button Grid.Column="6" Content="Clear" Style="{StaticResource ClearBtn}"
                            VerticalAlignment="Bottom" Click="btnClearFilters_Click"/>
                </Grid>

                <!-- Results list -->
                <ListBox Name="lbActions" Style="{StaticResource LibraryList}"
                         DisplayMemberPath="DisplayName"
                         MaxHeight="150" Margin="0,0,0,8"/>

                <!-- Apply row -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Name="lblProficiency" Grid.Column="1"
                               FontFamily="Georgia" FontSize="13" FontWeight="Bold"
                               Foreground="#AAE69A28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Grid.Column="3" Content="Apply"
                            Style="{StaticResource AmberBtn}" Padding="18,7"
                            Click="btnApply_Click"/>
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="#33E69A28" Margin="0,14,0,14"/>

                <!-- ── GENERATE ───────────────────────────────────────── -->
                <TextBlock Text="GENERATE" Style="{StaticResource SectionLabel}"/>

                <!-- Row 1: Name + Action type flags -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="NAME" Style="{StaticResource Lbl}"/>
                        <ComboBox Name="cboName" Style="{StaticResource DarkEditCombo}"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  Text="{Binding Action.Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,4">
                        <CheckBox Name="chkLegendary" IsChecked="{Binding Action.IsLegendary}"
                                  Content="Legendary" Style="{StaticResource DarkCheck}" Margin="0,0,14,0"/>
                        <CheckBox Name="chkBonus" IsChecked="{Binding Action.IsBonus}"
                                  Content="Bonus" Style="{StaticResource DarkCheck}" Margin="0,0,14,0"/>
                        <CheckBox Name="chkReaction" IsChecked="{Binding Action.IsReaction}"
                                  Content="Reaction" Style="{StaticResource DarkCheck}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Range + Attack Ability + bonus label -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="RANGE" Style="{StaticResource Lbl}"/>
                        <ComboBox Name="cboRange" Style="{StaticResource DarkEditCombo}"
                                  IsEditable="True" IsTextSearchEnabled="True"
                                  Text="{Binding Action.Range, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ATTACK ABILITY" Style="{StaticResource Lbl}"/>
                        <ComboBox Name="cboAttackAbility" Style="{StaticResource DarkCombo}"
                                  SelectionChanged="cboAttackAbility_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,4">
                        <TextBlock Name="lblCalculatedBonus"
                                   FontFamily="Georgia" FontSize="12" FontStyle="Italic"
                                   Foreground="#88E69A28" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3: Damage Dice + Damage Bonus + Damage Type -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DAMAGE DICE" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtDamageDice" Text="{Binding Action.DamageDice, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkInput}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DAMAGE BONUS" Style="{StaticResource Lbl}"/>
                        <TextBox Name="txtDamageBonus" Text="{Binding Action.DamageBonus, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkInput}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="DAMAGE TYPE" Style="{StaticResource Lbl}"/>
                        <ComboBox Name="cboDamageType" Style="{StaticResource DarkCombo}"
                                  SelectedItem="{Binding Action.DamageType}"/>
                    </StackPanel>
                </Grid>

                <!-- Generate button -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                    <Button Content="Generate Description" Style="{StaticResource AmberBtn}"
                            Padding="18,7" Click="btnGenerate_Click"/>
                </StackPanel>

                <!-- Separator -->
                <Border Height="1" Background="#33E69A28" Margin="0,14,0,14"/>

                <!-- ── DESCRIPTION ────────────────────────────────────── -->
                <TextBlock Text="DESCRIPTION" Style="{StaticResource Lbl}"/>
                <TextBox Name="txtDescription"
                         Text="{Binding Action.Description, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource DarkInput}"
                         AcceptsReturn="True" Height="180" TextWrapping="Wrap"
                         VerticalContentAlignment="Top" Padding="8,6"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F50A0000"
                BorderBrush="#33E69A28" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="btnCancel_Click"/>
                <Button Content="Save"   Style="{StaticResource AmberBtn}"                  Click="btnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
