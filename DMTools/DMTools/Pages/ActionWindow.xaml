<Window x:Class="DMTools.Pages.ActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Action" Height="580" Width="800" ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: From existing -->
        <Label Content="From existing" Grid.Column="0" Grid.Row="0" VerticalAlignment="Top" Margin="0,10,0,0"/>
        <ComboBox Name="cboActions" Grid.Column="1" Grid.Row="0" Height="25"
                  DisplayMemberPath="DisplayName" SelectedItem="{Binding SelectedDisplayAction}"
                  VerticalAlignment="Top" Margin="0,10,0,0"
                  IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="DisplayName"/>
        <Button Name="btnApply" Content="Apply" Grid.Column="1" Grid.Row="0" Width="100"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,6" Click="btnApply_Click"/>
        <Separator Grid.ColumnSpan="2" Grid.Row="0" VerticalAlignment="Bottom"/>

        <!-- Row 1: Name -->
        <Label Content="Name" Grid.Column="0" Grid.Row="1" VerticalAlignment="Center"/>
        <ComboBox Name="cboName" Grid.Column="1" Grid.Row="1" IsEditable="True"
                  Text="{Binding Action.Name, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="2"/>

        <!-- Row 2: Description -->
        <Label Content="Description" Grid.Column="0" Grid.Row="2" VerticalAlignment="Top" Margin="0,4,0,0"/>
        <TextBox Text="{Binding Action.Description}" Grid.Column="1" Grid.Row="2"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="2"/>

        <!-- Row 3: Range -->
        <Label Content="Range" Grid.Column="0" Grid.Row="3" VerticalAlignment="Center"/>
        <ComboBox Name="cboRange" Grid.Column="1" Grid.Row="3" IsEditable="True"
                  Text="{Binding Action.Range, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="2"/>

        <!-- Row 4: Damage Type -->
        <Label Content="Damage Type" Grid.Column="0" Grid.Row="4" VerticalAlignment="Center"/>
        <ComboBox Name="cboDamageType" Grid.Column="1" Grid.Row="4"
                  SelectedItem="{Binding Action.DamageType}" VerticalAlignment="Center" Margin="2"/>

        <!-- Row 5: Damage Dice -->
        <Label Content="Damage Dice" Grid.Column="0" Grid.Row="5" VerticalAlignment="Center"/>
        <TextBox Text="{Binding Action.DamageDice}" Grid.Column="1" Grid.Row="5" VerticalAlignment="Center" Margin="2"/>

        <!-- Row 6: Damage Bonus -->
        <Label Content="Damage Bonus" Grid.Column="0" Grid.Row="6" VerticalAlignment="Center"/>
        <TextBox Text="{Binding Action.DamageBonus}" Grid.Column="1" Grid.Row="6" VerticalAlignment="Center" Margin="2"/>

        <!-- Row 7: Attack Ability -->
        <Label Content="Attack Ability" Grid.Column="0" Grid.Row="7" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Grid.Row="7" Orientation="Horizontal" VerticalAlignment="Center">
            <ComboBox Name="cboAttackAbility" Width="80" Margin="2"
                      SelectedItem="{Binding Action.AttackAbility}"
                      SelectionChanged="cboAttackAbility_SelectionChanged"/>
            <TextBlock Name="lblCalculatedBonus" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" FontStyle="Italic"/>
        </StackPanel>

        <!-- Row 8: Attack Bonus -->
        <Label Content="Attack Bonus" Grid.Column="0" Grid.Row="8" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Grid.Row="8" Orientation="Horizontal" VerticalAlignment="Center">
            <CheckBox Name="chkOverride" Content="Override" IsChecked="{Binding Action.OverrideAttackBonus}"
                      VerticalAlignment="Center" Margin="2,0,10,0"
                      Checked="chkOverride_Changed" Unchecked="chkOverride_Changed"/>
            <TextBox Name="txtAttackBonus" Text="{Binding Action.AttackBonus}" Width="60" Margin="2"
                     IsEnabled="{Binding Action.OverrideAttackBonus}"/>
        </StackPanel>

        <!-- Row 9: Action type flags -->
        <Label Content="Action Type" Grid.Column="0" Grid.Row="9" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Grid.Row="9" Orientation="Horizontal" VerticalAlignment="Center">
            <CheckBox IsChecked="{Binding Action.IsLegendary}" Content="Legendary" Margin="2,0,15,0" VerticalAlignment="Center"/>
            <CheckBox IsChecked="{Binding Action.IsBonus}" Content="Bonus Action" Margin="0,0,15,0" VerticalAlignment="Center"/>
            <CheckBox IsChecked="{Binding Action.IsReaction}" Content="Reaction" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Row 10: Save -->
        <Button Name="btnSave" Content="Save" Grid.Column="1" Grid.Row="10" Width="100"
                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Click="btnSave_Click"/>
    </Grid>
</Window>
