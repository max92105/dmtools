<Page x:Class="DMTools.Pages.PcEditionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DMTools.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Loaded="Page_Loaded" Title="Pc Manager">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="10*" />
            <RowDefinition Height="90*" />
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="/Ressource/Header.png" Stretch="Fill"/>
        <Label Grid.Row="0" Content="Player Characters" FontWeight="Bold" FontSize="50" 
               HorizontalAlignment="Center" VerticalAlignment="top" Foreground="White"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="45*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="45*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <Button Name="btnSave" Content="Save" Click="btnSave_Click"/>
                <Button Name="btnDelete" Content="Delete" Click="btnDelete_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Label Content="Name"/>
                <TextBox Name="txtName" Text="{Binding PlayerCharacter.Name}"/>

                <Label Content="Armor Class"/>
                <TextBox Name="txtArmorClass" Text="{Binding PlayerCharacter.ArmorClass}"/>
            </StackPanel>
            <StackPanel Grid.Column="4">
                <Label Content="Initiative Bonus"/>
                <TextBox Name="txtInitiativeBonus" Text="{Binding PlayerCharacter.InitiativeBonus}"/>

                <Label Content="Level"/>
                <TextBox Name="txtLevel" Text="{Binding PlayerCharacter.Level}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
