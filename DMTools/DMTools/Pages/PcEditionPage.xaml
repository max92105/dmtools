<Page x:Class="DMTools.Pages.PcEditionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720" d:DesignWidth="1280"
      Background="#F2080000"
      Loaded="Page_Loaded" Title="Player Characters">

    <Page.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
            <Setter Property="SelectionBrush" Value="#44E69A28"/>
        </Style>
        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#E69A28"/>
            <Setter Property="Background" Value="#44E69A28"/>
            <Setter Property="BorderBrush" Value="#88E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Foreground" Value="#C07070"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55C42B1A"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F50A0000" BorderBrush="#55E69A28" BorderThickness="0,0,0,1" Padding="24,0">
            <TextBlock Text="Player Characters" FontFamily="Georgia" FontSize="22" FontStyle="Italic"
                       Foreground="#FFE69A28" VerticalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <Grid Grid.Row="1" MaxWidth="560" HorizontalAlignment="Left" Margin="32,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="NAME" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="txtName" Style="{StaticResource DarkInput}"
                         Text="{Binding PlayerCharacter.Name}"/>
            </StackPanel>

            <!-- Level + AC -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="LEVEL" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="txtLevel" Style="{StaticResource DarkInput}"
                             Text="{Binding PlayerCharacter.Level}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ARMOR CLASS" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="txtArmorClass" Style="{StaticResource DarkInput}"
                             Text="{Binding PlayerCharacter.ArmorClass}"/>
                </StackPanel>
            </Grid>

            <!-- Initiative -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="INITIATIVE BONUS" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="txtInitiativeBonus" Style="{StaticResource DarkInput}"
                         Text="{Binding PlayerCharacter.InitiativeBonus}"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Grid.Row="6" Height="1" Fill="#22E69A28"/>

            <!-- Buttons -->
            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnDelete" Grid.Column="0" Content="Delete"
                        Style="{StaticResource DangerBtn}" Click="btnDelete_Click"/>
                <Button x:Name="btnSave" Grid.Column="2" Content="Save"
                        Style="{StaticResource AmberBtn}" Click="btnSave_Click"/>
            </Grid>

        </Grid>
    </Grid>
</Page>
