<Window x:Class="DMTools.Pages.SpeedSenseEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Entry" Width="340" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Background="#F2080000">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
            <Setter Property="SelectionBrush" Value="#66E69A28"/>
        </Style>
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#44FFFFFF"/>
            <Setter Property="Foreground" Value="#F5E6D3"/>
            <Setter Property="BorderBrush" Value="#77E69A28"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1" Cursor="Hand" Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                                  VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#88E69A28"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                           FontSize="10"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False" Margin="9,0,28,0"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="#F5E6D3"
                                              TextBlock.FontFamily="Georgia"
                                              TextBlock.FontSize="12"/>
                            <Popup x:Name="PART_Popup" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#F0120000" BorderBrush="#88E69A28" BorderThickness="1" CornerRadius="1">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#F5E6D3"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontFamily" Value="Georgia"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33E69A28"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#55E69A28"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFE69A28"/>
            <Setter Property="Background" Value="#66E69A28"/>
            <Setter Property="BorderBrush" Value="#AAE69A28"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AmberBtn}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#55E69A28"/>
            <Setter Property="Foreground" Value="#CCE6D3B8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F50A0000"
                BorderBrush="#55E69A28" BorderThickness="0,0,0,1" Padding="16,12">
            <TextBlock x:Name="lblHeader" Text="Add Entry"
                       FontFamily="Georgia" FontSize="16" FontStyle="Italic"
                       Foreground="#FFE69A28"/>
        </Border>

        <!-- Fields -->
        <StackPanel Grid.Row="1" Margin="16,14,16,6">
            <TextBlock Text="TYPE" Style="{StaticResource Lbl}"/>
            <ComboBox Name="cboType" Style="{StaticResource DarkCombo}" Margin="0,0,0,12"/>

            <TextBlock Text="VALUE (FT.)" Style="{StaticResource Lbl}"/>
            <TextBox Name="txtValue" Text="30" Style="{StaticResource DarkInput}"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F50A0000"
                BorderBrush="#33E69A28" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="btnCancel_Click"/>
                <Button Content="OK"     Style="{StaticResource AmberBtn}"                  Click="btnOk_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
