<Window x:Class="DMTools.Pages.PcEditionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        WindowStyle="None" ResizeMode="NoResize"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#F2100800">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#99E69A28"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderBrush" Value="#44E69A28"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="CaretBrush" Value="#E69A28"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#E69A28" BorderThickness="1">
        <StackPanel>

            <!-- Title bar -->
            <Grid Height="38" Background="#CC0A0000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="tbTitle" Text="Player Character"
                           FontFamily="Georgia" FontSize="14" FontStyle="Italic"
                           Foreground="#E69A28" VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Content="&#x2715;" Click="Close_Click"
                        HorizontalAlignment="Right" Width="38" Height="38"
                        FontFamily="Segoe UI" FontSize="13"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#88E6D3B8" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#CCC42B1A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#88E6D3B8"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Rectangle Height="1" VerticalAlignment="Bottom" Fill="#33E69A28"/>
            </Grid>

            <!-- Form -->
            <StackPanel Margin="24,20,24,8">

                <!-- Name (full width) -->
                <TextBlock Text="NAME" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="txtName" Style="{StaticResource FieldBox}" Margin="0,0,0,16"/>

                <!-- Row: Level + AC -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LEVEL (1–20)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtLevel" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ARMOR CLASS" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtArmorClass" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Row: Initiative + Passive Perception -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="INITIATIVE BONUS" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtInitiativeBonus" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PASSIVE PERCEPTION" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtPassivePerception" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Max HP (half width) -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MAX HP" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtMaxHp" Style="{StaticResource FieldBox}"/>
                    </StackPanel>
                </Grid>

            </StackPanel>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#22E69A28" Margin="24,4,24,0"/>

            <!-- Buttons -->
            <Grid Margin="24,14,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnDelete" Grid.Column="0" Content="Delete"
                        Style="{StaticResource DialogButton}"
                        Background="Transparent" BorderBrush="#55C42B1A"
                        Foreground="#C07070" Visibility="Collapsed"
                        Click="btnDelete_Click"/>

                <Button Grid.Column="2" Content="Cancel"
                        Style="{StaticResource DialogButton}"
                        Background="Transparent" BorderBrush="#44E69A28"
                        Foreground="#99E6D3B8"
                        Click="btnCancel_Click"/>

                <Button Grid.Column="4" Content="Save"
                        Style="{StaticResource DialogButton}"
                        Background="#44E69A28" BorderBrush="#88E69A28"
                        Foreground="#E69A28"
                        Click="btnSave_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
