<Page x:Class="DMTools.Pages.MonsterEditionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="1280"
      Loaded="Page_Loaded" Title="Monster Manager" >
    <Page.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Image Source="/Ressource/Header.png" Stretch="Fill"/>
            <Label Content="Monsters" FontWeight="Bold" FontSize="50" 
                   HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,5">
                    <Button Name="btnSave" Content="Save" Width="80" Margin="2" Click="btnSave_Click"/>
                    <Button Name="btnCopy" Content="Copy" Width="80" Margin="2" Click="btnCopy_Click"/>
                    <Button Name="btnDelete" Content="Delete" Width="80" Margin="2" Click="btnDelete_Click"/>
                    <Button Name="btnSeeHtml" Width="120" Margin="2" Click="btnSeeHtml_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Ressource/HtmlPop.png" Width="16" Height="16"/>
                            <TextBlock Text="See StatBlock" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Basic Info -->
                <GroupBox Grid.Row="1" Header="Basic Information" Margin="0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="Name" Grid.Row="0" Grid.Column="0"/>
                        <TextBox Text="{Binding Monster.Name}" Grid.Row="0" Grid.Column="1"/>

                        <Label Content="Size" Grid.Row="0" Grid.Column="2"/>
                        <ComboBox Name="cboSize" SelectedItem="{Binding Monster.Size}" Grid.Row="0" Grid.Column="3"/>

                        <Label Content="Challenge" Grid.Row="0" Grid.Column="4"/>
                        <TextBox Text="{Binding Monster.ChallengeRating}" Grid.Row="0" Grid.Column="5"/>

                        <Label Content="Type" Grid.Row="1" Grid.Column="0"/>
                        <ComboBox Name="cboType" SelectedItem="{Binding Monster.Type}" Grid.Row="1" Grid.Column="1" IsEditable="True"/>

                        <Label Content="Subtype" Grid.Row="1" Grid.Column="2"/>
                        <ComboBox Name="cboSubtype" SelectedItem="{Binding Monster.Subtype}" Grid.Row="1" Grid.Column="3" IsEditable="True"/>

                        <Label Content="Alignment" Grid.Row="1" Grid.Column="4"/>
                        <ComboBox Name="cboAlignment" SelectedItem="{Binding Monster.Alignment}" Grid.Row="1" Grid.Column="5" IsEditable="True"/>

                        <Label Content="Hit Points" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding Monster.HitPoints}" Grid.Row="2" Grid.Column="1"/>
                    </Grid>
                </GroupBox>

                <!-- AC, Speeds, Senses -->
                <GroupBox Grid.Row="2" Header="Combat Stats" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Armor Class -->
                        <GroupBox Header="Armor Class" Grid.Column="0" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox Name="lbArmorClass" ItemsSource="{Binding ArmorClassEntries}" DisplayMemberPath="Display" 
                                         Grid.Row="0" MinHeight="80"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="Add" Width="60" Margin="2" Click="btnAddAc_Click"/>
                                    <Button Content="Remove" Width="60" Margin="2" Click="btnRemoveAc_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Speeds -->
                        <GroupBox Header="Speed" Grid.Column="1" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox Name="lbSpeeds" ItemsSource="{Binding Speeds}" DisplayMemberPath="Display" 
                                         Grid.Row="0" MinHeight="80"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="Add" Width="60" Margin="2" Click="btnAddSpeed_Click"/>
                                    <Button Content="Remove" Width="60" Margin="2" Click="btnRemoveSpeed_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Senses -->
                        <GroupBox Header="Senses" Grid.Column="2" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox Name="lbSenses" ItemsSource="{Binding Senses}" DisplayMemberPath="Display" 
                                         Grid.Row="0" MinHeight="80"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="Add" Width="60" Margin="2" Click="btnAddSense_Click"/>
                                    <Button Content="Remove" Width="60" Margin="2" Click="btnRemoveSense_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </GroupBox>

                <!-- Damage Modifiers, Condition Immunities, Languages -->
                <GroupBox Grid.Row="3" Header="Defenses &amp; Languages" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Damage Modifiers -->
                        <GroupBox Header="Damage Modifiers (Homebrew)" Grid.Column="0" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox Name="lbDamageModifiers" ItemsSource="{Binding DamageModifiers}" DisplayMemberPath="Display" 
                                         Grid.Row="0" MinHeight="100"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="Add" Width="60" Margin="2" Click="btnAddDamageModifier_Click"/>
                                    <Button Content="Remove" Width="60" Margin="2" Click="btnRemoveDamageModifier_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Condition Immunities -->
                        <GroupBox Header="Condition Immunities" Grid.Column="1" Margin="2">
                            <ListBox Name="lbConditionImmunities" MinHeight="100" SelectionMode="Multiple"
                                     SelectionChanged="lbConditionImmunities_SelectionChanged"/>
                        </GroupBox>

                        <!-- Languages -->
                        <GroupBox Header="Languages" Grid.Column="2" Margin="2">
                            <ListBox Name="lbLanguages" MinHeight="100" SelectionMode="Multiple"
                                     SelectionChanged="lbLanguages_SelectionChanged"/>
                        </GroupBox>
                    </Grid>
                </GroupBox>

                <!-- Characteristics -->
                <GroupBox Grid.Row="4" Header="Ability Scores" Margin="0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Content="" Grid.Row="0" Grid.Column="0"/>
                        <Label Content="STR" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center"/>
                        <Label Content="DEX" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center"/>
                        <Label Content="CON" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center"/>
                        <Label Content="INT" Grid.Row="0" Grid.Column="4" HorizontalAlignment="Center"/>
                        <Label Content="WIS" Grid.Row="0" Grid.Column="5" HorizontalAlignment="Center"/>
                        <Label Content="CHA" Grid.Row="0" Grid.Column="6" HorizontalAlignment="Center"/>

                        <Label Content="Score" Grid.Row="1" Grid.Column="0"/>
                        <TextBox Text="{Binding Strength.Score}" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"/>
                        <TextBox Text="{Binding Dexterity.Score}" Grid.Row="1" Grid.Column="2"/>
                        <TextBox Text="{Binding Constitution.Score}" Grid.Row="1" Grid.Column="3"/>
                        <TextBox Text="{Binding Intelligence.Score}" Grid.Row="1" Grid.Column="4"/>
                        <TextBox Text="{Binding Wisdom.Score}" Grid.Row="1" Grid.Column="5"/>
                        <TextBox Text="{Binding Charisma.Score}" Grid.Row="1" Grid.Column="6"/>

                        <Label Content="Save" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding Strength.Save}" Grid.Row="2" Grid.Column="1"/>
                        <TextBox Text="{Binding Dexterity.Save}" Grid.Row="2" Grid.Column="2"/>
                        <TextBox Text="{Binding Constitution.Save}" Grid.Row="2" Grid.Column="3"/>
                        <TextBox Text="{Binding Intelligence.Save}" Grid.Row="2" Grid.Column="4"/>
                        <TextBox Text="{Binding Wisdom.Save}" Grid.Row="2" Grid.Column="5"/>
                        <TextBox Text="{Binding Charisma.Save}" Grid.Row="2" Grid.Column="6"/>
                    </Grid>
                </GroupBox>

                <!-- Skills, Special Abilities, Actions -->
                <GroupBox Grid.Row="5" Header="Abilities" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Skills -->
                        <GroupBox Header="Skills" Grid.Column="0" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox Name="lbDisplaySkill" ItemsSource="{Binding DisplaySkills}" DisplayMemberPath="Name"
                                         SelectedItem="{Binding Path=SelectedSkill, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                         Grid.Row="0" MinHeight="150"/>
                                <Button Name="btnEditSkills" Content="Edit" Grid.Row="1" Width="80" HorizontalAlignment="Left" Margin="2" Click="btnEditSkills_Click"/>
                            </Grid>
                        </GroupBox>

                        <!-- Special Abilities -->
                        <GroupBox Header="Special Abilities" Grid.Column="1" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox ItemsSource="{Binding SpecialAbilities}" DisplayMemberPath="Name"
                                         SelectedItem="{Binding Path=SelectedSpecialAbility, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                         Grid.Row="0" MinHeight="150"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="New" Width="60" Margin="2" Click="btnNewSpecialAbilities_Click"/>
                                    <Button Content="Edit" Width="60" Margin="2" Click="btnEditSpecialAbilities_Click"/>
                                    <Button Content="Delete" Width="60" Margin="2" Click="btnDeleteSpecialAbilities_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Actions -->
                        <GroupBox Header="Actions" Grid.Column="2" Margin="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <ListBox ItemsSource="{Binding Actions}" DisplayMemberPath="Name"
                                         SelectedItem="{Binding Path=SelectedAction, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                         Grid.Row="0" MinHeight="150"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="New" Width="60" Margin="2" Click="btnNewActions_Click"/>
                                    <Button Content="Edit" Width="60" Margin="2" Click="btnEditActions_Click"/>
                                    <Button Content="Delete" Width="60" Margin="2" Click="btnDeleteActions_Click"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </GroupBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
