<Window x:Class="DMTools.Pages.ConditionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#F2100800">

    <Window.Resources>
        <Style x:Key="CondToggle" TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="#22FFFFFF"
                                BorderBrush="#33E69A28" BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#55E69A28"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#BBE69A28"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33E69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton" BasedOn="{StaticResource CondToggle}">
            <Setter Property="Foreground" Value="#F0E6D3"/>
        </Style>

        <Style x:Key="ImmuneToggle" TargetType="ToggleButton" BasedOn="{StaticResource CondToggle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="#22FFFFFF"
                                BorderBrush="#33C42B1A" BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#44C42B1A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#88C42B1A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33C42B1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExhBtn" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#F0E6D3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#22FFFFFF"
                                BorderBrush="#44E69A28" BorderThickness="1" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33E69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#E69A28" BorderThickness="1">
        <StackPanel>

            <!-- Title bar -->
            <Grid Height="38" Background="#CC0A0000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="tbTitle" Text="Conditions"
                           FontFamily="Georgia" FontSize="14" FontStyle="Italic"
                           Foreground="#E69A28" VerticalAlignment="Center" Margin="14,0,0,0"/>
                <Button Content="&#x2715;" Click="btnClose_Click"
                        HorizontalAlignment="Right" Width="38" Height="38"
                        FontFamily="Segoe UI" FontSize="13" Background="Transparent" BorderThickness="0"
                        Foreground="#88E6D3B8" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#CCC42B1A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="#88E6D3B8"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Rectangle Height="1" VerticalAlignment="Bottom" Fill="#33E69A28"/>
            </Grid>

            <!-- Immune note if any -->
            <TextBlock x:Name="tbImmuneNote" Margin="16,10,16,0"
                       FontFamily="Georgia" FontSize="10" Foreground="#BBAA3030"
                       TextWrapping="Wrap" Visibility="Collapsed"/>

            <!-- Conditions grid -->
            <WrapPanel Margin="12,12,12,4" Orientation="Horizontal">
                <ToggleButton x:Name="tbBlinded"       CommandParameter="Blinded"       Click="ToggleCond_Click">Blinded</ToggleButton>
                <ToggleButton x:Name="tbCharmed"       CommandParameter="Charmed"       Click="ToggleCond_Click">Charmed</ToggleButton>
                <ToggleButton x:Name="tbDeafened"      CommandParameter="Deafened"      Click="ToggleCond_Click">Deafened</ToggleButton>
                <ToggleButton x:Name="tbFrightened"    CommandParameter="Frightened"    Click="ToggleCond_Click">Frightened</ToggleButton>
                <ToggleButton x:Name="tbGrappled"      CommandParameter="Grappled"      Click="ToggleCond_Click">Grappled</ToggleButton>
                <ToggleButton x:Name="tbIncapacitated" CommandParameter="Incapacitated" Click="ToggleCond_Click">Incapacitated</ToggleButton>
                <ToggleButton x:Name="tbInvisible"     CommandParameter="Invisible"     Click="ToggleCond_Click">Invisible</ToggleButton>
                <ToggleButton x:Name="tbParalyzed"     CommandParameter="Paralyzed"     Click="ToggleCond_Click">Paralyzed</ToggleButton>
                <ToggleButton x:Name="tbPetrified"     CommandParameter="Petrified"     Click="ToggleCond_Click">Petrified</ToggleButton>
                <ToggleButton x:Name="tbPoisoned"      CommandParameter="Poisoned"      Click="ToggleCond_Click">Poisoned</ToggleButton>
                <ToggleButton x:Name="tbProne"         CommandParameter="Prone"         Click="ToggleCond_Click">Prone</ToggleButton>
                <ToggleButton x:Name="tbRestrained"    CommandParameter="Restrained"    Click="ToggleCond_Click">Restrained</ToggleButton>
                <ToggleButton x:Name="tbStunned"       CommandParameter="Stunned"       Click="ToggleCond_Click">Stunned</ToggleButton>
                <ToggleButton x:Name="tbUnconscious"   CommandParameter="Unconscious"   Click="ToggleCond_Click">Unconscious</ToggleButton>
            </WrapPanel>

            <!-- Exhaustion row -->
            <StackPanel Orientation="Horizontal" Margin="16,4,16,12">
                <TextBlock Text="EXHAUSTION" FontFamily="Georgia" FontSize="10" FontWeight="Bold"
                           Foreground="#99E69A28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="−" Click="btnDecExh_Click" Style="{StaticResource ExhBtn}"/>
                <TextBlock x:Name="tbExhLevel" Text="0" Width="24"
                           FontFamily="Georgia" FontSize="14" Foreground="#E69A28"
                           VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                <Button Content="+" Click="btnIncExh_Click" Style="{StaticResource ExhBtn}"/>
            </StackPanel>

            <Rectangle Height="1" Fill="#22E69A28" Margin="16,0,16,0"/>

            <!-- Close button -->
            <Grid Margin="16,12,16,16" HorizontalAlignment="Right">
                <Button Content="Close" Click="btnClose_Click"
                        FontFamily="Georgia" FontSize="13" Padding="20,7"
                        Background="#44E69A28" BorderBrush="#88E69A28" Foreground="#E69A28"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="FontFamily" Value="Georgia"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="20,7"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

        </StackPanel>
    </Border>
</Window>
