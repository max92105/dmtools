<Window x:Class="DMTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Closed="Window_Closed"
        Title="DM Tools" Width="1280" Height="720" WindowState="Maximized"
        WindowStyle="None" ResizeMode="CanResize">

    <Window.Resources>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#99E6D3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33E69A28"/>
                                <Setter Property="Foreground" Value="#E69A28"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#66E69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#99E6D3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#CCC42B1A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#99C42B1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BackButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#99E6D3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <TextBlock x:Name="arrow" Text="&#x2190;"
                                       FontFamily="Segoe UI" FontSize="16"
                                       LineHeight="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="-2"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33E69A28"/>
                                <Setter TargetName="arrow" Property="Foreground" Value="#E69A28"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#66E69A28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid Grid.Row="0" Background="#E6100800"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Back button + icon + title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="btnBack" Style="{StaticResource BackButtonStyle}"
                        Click="Back_Click" ToolTip="Back" Visibility="Collapsed"/>
                <Image Source="/Ressource/DNDIcon.ico" Width="16" Height="16"
                       Margin="10,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"/>
                <TextBlock x:Name="tbPageTitle" Text="DM Tools" FontFamily="Georgia"
                           FontSize="13" FontStyle="Italic"
                           Foreground="#E69A28" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Bottom border line -->
            <Rectangle Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom" Fill="#33E69A28"/>

            <!-- Window controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="&#x2212;" Style="{StaticResource ChromeButtonStyle}"
                        Click="Minimize_Click" ToolTip="Minimize"/>
                <Button x:Name="btnMaxRestore" Content="&#x25A1;" Style="{StaticResource ChromeButtonStyle}"
                        Click="MaximizeRestore_Click" ToolTip="Maximize"/>
                <Button Content="&#x2715;" Style="{StaticResource CloseButtonStyle}"
                        Click="Close_Click" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Page content -->
        <Frame x:Name="MainFrame" Grid.Row="1" Source="/Pages/MainPage.xaml"
               NavigationUIVisibility="Hidden"
               Navigated="MainFrame_Navigated"/>
    </Grid>
</Window>
